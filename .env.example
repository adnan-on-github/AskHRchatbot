# ── Provider ("openai" | "huggingface") ─────────────────────────────────
# LLM_PROVIDER sets the default shown in the Streamlit sidebar (users can override per session)
LLM_PROVIDER=openai
# EMBEDDING_PROVIDER controls which model is used for ChromaDB at ingest/retrieval time
# Change this before the first ingest — mixing providers across ingests will cause dim mismatches
EMBEDDING_PROVIDER=openai

# ── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── HuggingFace ──────────────────────────────────────────────────────────
# Required when provider=huggingface + hf_access_mode=api
HF_API_TOKEN=hf_...
# Default HF models (overridable)
HF_LLM_MODEL=meta-llama/Llama-3-8B-Instruct
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# "api" = HuggingFace Inference API (remote) | "local" = load weights locally
HF_ACCESS_MODE=api

# ── ChromaDB ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=askhr_docs

# ── RAG tuning ───────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-3-small

# ── Server ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
RATE_LIMIT=20/minute

# ── Streamlit frontend ───────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

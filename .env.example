# =============================================================================
# LOCAL DEVELOPMENT — standard OpenAI
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# AZURE DEPLOYMENT — fill these in instead of OPENAI_API_KEY
# Set USE_MANAGED_IDENTITY=true in Azure Container Apps (no API key needed).
# For local dev against Azure OpenAI, set USE_MANAGED_IDENTITY=false and
# provide AZURE_OPENAI_API_KEY.
# =============================================================================
USE_MANAGED_IDENTITY=false
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=                          # leave empty when using MI
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Set by the provisioning script — identifies the user-assigned Managed Identity
# AZURE_CLIENT_ID=<managed-identity-client-id>

# =============================================================================
# ChromaDB
# =============================================================================
CHROMA_PERSIST_DIR=./chroma_db               # overridden to /mnt/chromadb in Azure
CHROMA_COLLECTION_NAME=askhr_docs

# =============================================================================
# RAG tuning
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Server
# =============================================================================
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
RATE_LIMIT=20/minute

# =============================================================================
# Streamlit frontend
# =============================================================================
BACKEND_URL=http://localhost:8000

# ── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── ChromaDB ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=askhr_docs

# ── RAG tuning ───────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-3-small

# ── Server ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
RATE_LIMIT=20/minute

# ── Streamlit frontend ───────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
